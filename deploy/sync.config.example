# Kopiere diese Datei nach  deploy/sync.config  und trage deine Werte ein.
# sync.config NICHT committen (steht in .gitignore).

# --- SSH-Zugang zum Server ---
SSH_HOST="dein.server.de"      # IP oder Hostname
SSH_USER="dks"                 # SSH-Benutzer
SSH_PORT="22"                  # Standard 22
SSH_KEY=""                     # optional: Pfad zum privaten Key, z. B. ~/.ssh/id_ed25519
                               # leer lassen = Passwort/Default-Key

# --- Zielpfade auf dem Server ---
REMOTE_APP_DIR="/opt/dks/redbot-dks-dashboard"   # Web-App (wie im Deploy)
REMOTE_COGS_DIR="/home/dks/dks-cogs"             # Cog-Repo-Pfad auf dem Server
                                                 # (der Ordner, den Red via [p]addpath kennt)

# --- Lokale Quellpfade (optional überschreiben) ---
# Standard: Web-App = dieser Repo-Ordner; Cogs = ../DKS_Redcogs daneben.
# In WSL liegen Windows-Laufwerke unter /mnt/, z. B.:
# LOCAL_APP_DIR="/mnt/w/_Git/DKS_Redbot_WebApp"
# LOCAL_COGS_DIR="/mnt/w/_Git/DKS_Redcogs"
