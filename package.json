    "svelte": "^4.2.18",
    "svelte-check": "^3.8.0",
    "tailwindcss": "^3.4.4",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "dependencies": {
