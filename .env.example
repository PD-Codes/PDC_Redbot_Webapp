# Discord OAuth2 (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback

# RPC gateway of the companion cog (webdashboard)
# Local (npm run dev):              http://127.0.0.1:6970
# In Docker, bot runs on the host:  http://host.docker.internal:6970
GATEWAY_URL=http://127.0.0.1:6970
# Get it with:  [p]pdcdashboard token
GATEWAY_TOKEN=

# Random, long secret for the signed session (e.g. `openssl rand -hex 32`)
SESSION_SECRET=

# Optional: enable the self-update button on /system (owner only). "true" allows
# starting deploy/update.sh (git pull + build + service restart) from the web panel.
# Requirement: the service user must be allowed to restart the service, e.g. via sudoers:
#   pdc ALL=(root) NOPASSWD: /usr/bin/systemctl restart pdc-redbot-webapp
ENABLE_SELF_UPDATE=false

# Optional overrides for deploy/update.sh (normally auto-detected):
#   REPO_URL      source repo to pull from (default: the new PDC WebApp repo)
#   SERVICE_NAME  systemd unit to restart (auto: pdc-redbot-webapp or legacy dks-dashboard)
#   SERVICE_USER  service user (auto: derived from the unit; pdc or legacy dks)
# REPO_URL=https://github.com/PD-Codes/PDC_Redbot_Webapp
# SERVICE_NAME=pdc-redbot-webapp
# SERVICE_USER=pdc
