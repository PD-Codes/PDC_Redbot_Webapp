# ============================================================================
# PDC Redbot Webapp — environment configuration
# Copy this file to `.env` and fill in the values. Never commit your real .env.
# ============================================================================

# ---- Discord OAuth2 (https://discord.com/developers/applications) ----------
# Application ID of your Discord application (usually the same app as the bot).
DISCORD_CLIENT_ID=
# OAuth2 client secret (Developer Portal -> OAuth2 -> Client Secret).
DISCORD_CLIENT_SECRET=
# OAuth2 redirect URI. Must be added VERBATIM to the application's
# OAuth2 -> Redirects list. Use your public URL in production, e.g.
#   https://dashboard.example.com/auth/callback
DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback

# ---- RPC gateway of the companion cog (pdc_webdashboard) -------------------
# URL where the cog's gateway listens (default bind: 127.0.0.1:6970,
# change with `[p]pdcdashboard bind <host> <port>` on the bot).
#   Local (npm run dev):                 http://127.0.0.1:6970
#   Docker, bot on the host machine:     http://host.docker.internal:6970
#   Docker compose, redbot service name: http://redbot:6970
GATEWAY_URL=http://127.0.0.1:6970
# Shared secret between webapp and cog. Get/rotate it on the bot with:
#   [p]pdcdashboard token
GATEWAY_TOKEN=

# ---- Docker compose only (consumed by the `redbot` service) ----------------
# Discord BOT token (Developer Portal -> Bot). Only needed when you run the
# bundled Red container from docker-compose.yml; a native Red install asks for
# it during `redbot-setup` instead.
DISCORD_BOT_TOKEN=
# Command prefix for the bot (compose default: !)
# BOT_PREFIX=!
# TZ=Europe/Berlin

# ---- Session ----------------------------------------------------------------
# Random, long secret used to sign session cookies. REQUIRED in production —
# the app refuses to start without it. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ---- Server (adapter-node) ---------------------------------------------------
# Address/port the Node server listens on (defaults inside Docker: 0.0.0.0:3000).
# HOST=0.0.0.0
# PORT=3000
# Public origin of the deployment, used by SvelteKit for CSRF/URL resolution
# when running behind a reverse proxy, e.g. https://dashboard.example.com
# ORIGIN=https://dashboard.example.com
# NODE_ENV=production
# Seconds adapter-node waits for open connections to end on SIGTERM/SIGINT
# before force-closing them (default: 30). The dashboard's SSE stream
# (/api/events) is always "active", never idle, so a stop/restart otherwise
# stalls for the full default before the process actually exits. Recommended:
# uncomment this (5s is plenty - the browser reconnects the SSE stream
# automatically).
SHUTDOWN_TIMEOUT=5

# ---- Optional ----------------------------------------------------------------
# Directory for persisted dashboard logs (default: ./data next to the app).
# LOG_STORE_DIR=/app/data

# Enable the self-update button on /system (owner only). "true" allows starting
# deploy/update.sh (git pull + build + service restart) from the web panel.
# Only meaningful for the native systemd deployment, NOT inside Docker.
# Requirement: the service user may restart the service, e.g. via sudoers:
#   pdc ALL=(root) NOPASSWD: /usr/bin/systemctl restart pdc-redbot-webapp
ENABLE_SELF_UPDATE=false

# Optional overrides for deploy/update.sh (normally auto-detected):
#   REPO_URL       source repo to pull from
#   DEPLOY_BRANCH  branch to pull (default: current branch)
#   SERVICE_NAME   systemd unit to restart (auto: pdc-redbot-webapp)
#   SERVICE_USER   service user (auto: derived from the unit)
# REPO_URL=https://github.com/PD-Codes/PDC_Redbot_Webapp
# DEPLOY_BRANCH=main
# SERVICE_NAME=pdc-redbot-webapp
# SERVICE_USER=pdc
